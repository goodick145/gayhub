    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer

    -- List animation IDs ...
    local BlockAnimations = {
        10469643643,10469639222,10469630950,10469493270, -- combat
        10479335397,13380255751, -- dash
        10468665991,10466974800,10471336737,12510170988, -- sai
        14516273501,12272894215,12296882427,12307656616,12351854556, -- ga
        12534735382,12502664044,12509505723,12618271998,12684390285,12684185971, -- cy
        13376869471,13294790250,13376962659,13365849295,13501296372, -- nin
        14003607057,14004235777,14046756619,14048349132,14299135500,14967219354,14351441234, -- chay
        15290930205,15145462680,15295895753,15311685628, -- blade
        16515850153,16139108718,16431491215,16597322398, -- tat
        17799224866,17838006839,17857788598,17857880283,18179181663 -- rui
    }

    local function Block()
        local args = {[1] = {Goal="KeyPress", Key=Enum.KeyCode.F}}
        LocalPlayer.Character.Communicate:FireServer(unpack(args))
    end
    local function Unblock()
        local args = {[1] = {Goal="KeyRelease", Key=Enum.KeyCode.F}}
        LocalPlayer.Character.Communicate:FireServer(unpack(args))
    end

    local function CheckAndBlock()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Head") then return end
        local myHead = char.Head

        local shouldBlock = false

        for _, enemy in ipairs(workspace.Live:GetChildren()) do
            if enemy:IsA("Model") and enemy ~= char and enemy:FindFirstChild("Head") then
                local dist = (enemy.Head.Position - myHead.Position).Magnitude
                if dist <= 15 then
                    local hum = enemy:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        if enemy:FindFirstChild("M1ing") then
                            shouldBlock = true
                            break
                        end
                        local animator = hum:FindFirstChildOfClass("Animator")
                        if animator then
                            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                                local id = tonumber(track.Animation.AnimationId:match("%d+"))
                                if id and table.find(BlockAnimations, id) then
                                    shouldBlock = true
                                    break
                                end
                            end
                        end
                    end
                end
            end
            if shouldBlock then break end
        end

        if shouldBlock then
            Block()
        else
            Unblock()
        end
    end

    if value then
        -- bật: tạo connection mới
        if AutoBlockConnection then AutoBlockConnection:Disconnect() end
        AutoBlockConnection = RunService.RenderStepped:Connect(function()
            pcall(CheckAndBlock)
        end)
    else
        -- tắt: hủy connection hiện tại
        if AutoBlockConnection then
            AutoBlockConnection:Disconnect()
            AutoBlockConnection = nil
        end
        Unblock()
    end
end)
