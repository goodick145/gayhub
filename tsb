tab5.newToggle("M1ing Teleport Vip Pro Max", "Tự động dịch chuyển khi kích hoạt M1ing", false, function(value)
	getgenv().AutoTeleportPunching = value;
	getgenv().DetectionDistance = 55;
	getgenv().TeleportBackDelay = 0.2;
	getgenv().RandomTeleportRadius = 25;
	local LPlayer = game.Players.LocalPlayer;
	local CRoot;
	local function UpdateCRoot()
		local LChar = LPlayer.Character;
		if LChar then
			CRoot = LChar:FindFirstChild("HumanoidRootPart");
			if not CRoot then
				LChar.ChildAdded:Wait();
				CRoot = LChar:WaitForChild("HumanoidRootPart");
			end
		end
	end
	local function FindNearestEnemy()
		local nearestDistance = getgenv().DetectionDistance;
		local nearestEnemy = nil;
		for _, v in pairs(game.Workspace.Live:GetChildren()) do
			local Humanoid = v:FindFirstChildOfClass("Humanoid");
			local HumanoidRoot = v:FindFirstChild("HumanoidRootPart");
			if (Humanoid and HumanoidRoot and (v ~= LPlayer.Character)) then
				if (Humanoid.Health > 0) then
					local distance = (CRoot.Position - HumanoidRoot.Position).magnitude;
					if (distance < nearestDistance) then
						nearestDistance = distance;
						nearestEnemy = HumanoidRoot;
					end
				end
			end
		end
		return nearestEnemy;
	end
	local function TeleportToRandomPosition(originalPosition)
		local randomAngle = math.rad(math.random(0, 360));
		local randomDistance = math.random(10, getgenv().RandomTeleportRadius);
		local xOffset = math.cos(randomAngle) * randomDistance;
		local zOffset = math.sin(randomAngle) * randomDistance;
		local newPosition = originalPosition.Position + Vector3.new(xOffset, 0, zOffset);
		game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(CFrame.new(newPosition));
	end
	if value then
		task.spawn(function()
			while getgenv().AutoTeleportPunching do
				pcall(function()
					UpdateCRoot();
					if workspace.Live[LPlayer.Name]:FindFirstChild("M1ing") then
						if CRoot then
							local target = FindNearestEnemy();
							if target then
								local originalPosition = CRoot.CFrame;
								local behindPosition = target.Position - (target.CFrame.LookVector * 3);
								game.Players.LocalPlayer.Character:SetPrimaryPartCFrame(CFrame.new(behindPosition, target.Position));
								task.wait(getgenv().TeleportBackDelay);
								TeleportToRandomPosition(CRoot.CFrame);
							end
						end
					end
				end);
				task.wait(0.015);
			end
		end);
	else
		getgenv().AutoTeleportPunching = false;
	end
end);
