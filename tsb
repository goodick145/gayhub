local function getFacingCFrame(pos)
    return CFrame.new(pos, Vector3.new(0, pos.Y, 0))
end

-- Hàm tìm target player, ưu tiên player ghim
local function getTargetPlayer()
    local targetPlayerModel = nil

    -- Nếu có player ghim
    if pinnedPlayerName and workspace:FindFirstChild("Live") then
        for _, plr in pairs(workspace.Live:GetChildren()) do
            if plr:FindFirstChild("HumanoidRootPart") and plr.Name:lower() == pinnedPlayerName:lower() then
                targetPlayerModel = plr
                break
            end
        end
    end

    -- Nếu player ghim không tồn tại, random player
    if not targetPlayerModel and workspace:FindFirstChild("Live") then
        for _, plr in pairs(workspace.Live:GetChildren()) do
            if plr:FindFirstChild("HumanoidRootPart") and plr.Name ~= LocalPlayer.Name then
                targetPlayerModel = plr
                break
            end
        end
    end

    return targetPlayerModel
end

-- Hàm chính
local function doAction()
    local index = 1
    while running do
        -- TP đến trash
        local targetTrash = trashPositions[index]
        index = index + 1
        if index > #trashPositions then index = 1 end

        if hrp then
            hrp.CFrame = getFacingCFrame(targetTrash) * CFrame.new(0,0,3)
        end

        task.wait(0.5)
        sendClick()
        task.wait(0.5)

        -- Target player
        local targetPlayerModel = getTargetPlayer()
        if targetPlayerModel then
            local targetHRP = targetPlayerModel:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                local followTime = 2
                local t = tick()
                while running and tick()-t < followTime do
                    if hrp then
                        hrp.CFrame = targetHRP.CFrame * CFrame.new(0,0,3)
                    end
                    sendClick()
                    task.wait(0.3)
                end
            end
        end

        task.wait(1)
    end
end

