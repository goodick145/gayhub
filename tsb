tab2.newToggle("Anti Counter TP", "Tự động né người có Counter gần bạn", false, function(value)
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer

    -- Hàm tìm player có Counter trong phạm vi 50 studs
    local function findNearbyCounterPlayer()
        local myChar = LocalPlayer.Character
        if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end

        local myPos = myChar.HumanoidRootPart.Position
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = plr.Character.HumanoidRootPart
                local accessory = plr.Character:FindFirstChild("Counter")
                if accessory and accessory:IsA("Accessory") then
                    local dist = (hrp.Position - myPos).Magnitude
                    if dist <= 100 then
                        return plr
                    end
                end
            end
        end
        return nil
    end

    local function handleTP()
        local counterPlayer = findNearbyCounterPlayer()
        if counterPlayer and counterPlayer.Character and counterPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local myChar = LocalPlayer.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local targetHRP = counterPlayer.Character.HumanoidRootPart

            if myHRP then
                local dir = (myHRP.Position - targetHRP.Position).Unit -- hướng từ họ → mình
                local newPos = targetHRP.Position + dir * 100 -- tp cách 50 studs
                myHRP.CFrame = CFrame.new(newPos)
            end
        end
    end

    if value then
        -- bật toggle → chạy loop
        if AutoCounterTPConnection then AutoCounterTPConnection:Disconnect() end
        AutoCounterTPConnection = RunService.Heartbeat:Connect(function()
            pcall(handleTP)
        end)
    else
        -- tắt toggle → ngắt kết nối
        if AutoCounterTPConnection then
            AutoCounterTPConnection:Disconnect()
            AutoCounterTPConnection = nil
        end
    end
end)
