                    local track = humanoid:LoadAnimation(anim)
                    track:Play()
                    track:AdjustSpeed(1)
                    task.wait(track.Length) -- đợi đúng thời lượng animation
                end)
            end
            task.wait(3) -- nghỉ 3s rồi lặp lại từ đầu
        end
    end

    -- Chạy ở thread riêng
    if value then
        task.spawn(playCombatAnimations)
    end
end)

